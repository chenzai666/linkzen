# 数据库（SQLite，路径相对于项目根目录）
DATABASE_URL="file:./data/wrdo.db"

# NextAuth
AUTH_SECRET="your-secret-key-change-this"
AUTH_URL="http://localhost:3000"

# 应用 URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="wr.do"

# Cloudflare（DNS 功能必填）
# CF_API_KEY=
# CF_EMAIL=

# 可选：GitHub Token（用于某些功能）
# GITHUB_TOKEN=
